{
  "name": "robomonitor-api",
  "version": "1.0.0",
  "description": "Real-time robot telemetry API with ML anomaly detection, WebSocket streaming, JWT auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run tests/unit.test.ts --reporter=verbose",
    "test:watch": "vitest tests/unit.test.ts",
    "test:coverage": "vitest run tests/unit.test.ts --coverage",
    "lint": "eslint src --ext .ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts",
    "test:integration": "vitest run tests/api.test.ts --reporter=verbose",
    "test:all": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.14.0",
    "fastify": "^4.27.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}