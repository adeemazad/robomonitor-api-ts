# Copy to .env — never commit .env to git

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Dev (SQLite, zero-setup):
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL — change prisma/schema.prisma provider to postgresql):
# DATABASE_URL="postgresql://user:password@host:5432/robomonitor?schema=public"

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_USE_A_RANDOM_32_CHAR_STRING
JWT_EXPIRES_IN=1h

# ── Anomaly detection ─────────────────────────────────────────────────────────
ANOMALY_WINDOW=30
ANOMALY_Z_THRESHOLD=3.5

# ── Simulator ─────────────────────────────────────────────────────────────────
SIMULATOR_HZ=10
